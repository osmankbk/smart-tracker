generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  MEMBER
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum OrderPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id             String   @id @default(cuid())
  organizationId String?

  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(MEMBER)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])

  assignedOrders Order[] @relation("AssignedOrders")
  createdOrders  Order[] @relation("CreatedOrders")
  activityLogs   ActivityLog[]
}

model Order {
  id             String        @id @default(cuid())
  organizationId String?

  title          String
  description    String?
  status         OrderStatus   @default(OPEN)
  priority       OrderPriority @default(MEDIUM)

  workflowId     String?
  statusId       String?

  assigneeId     String?
  createdById    String?

  organization   Organization?   @relation(fields: [organizationId], references: [id])
  workflow       Workflow?       @relation(fields: [workflowId], references: [id])
  statusRef      WorkflowStatus? @relation(fields: [statusId], references: [id])

  assignee       User? @relation("AssignedOrders", fields: [assigneeId], references: [id])
  createdBy      User? @relation("CreatedOrders", fields: [createdById], references: [id])

  activityLogs   ActivityLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ActivityLog {
  id      String  @id @default(cuid())
  orderId String
  actorId String?

  action     String
  fromStatus OrderStatus?
  toStatus   OrderStatus?

  reason String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
  actor User? @relation(fields: [actorId], references: [id])
}


model Workflow {
  id             String   @id @default(cuid())
  organizationId String?

  name           String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])

  statuses       WorkflowStatus[]
  transitions    WorkflowTransition[]
  orders         Order[]
}

model WorkflowStatus {
  id          String   @id @default(cuid())
  workflowId String

  name        String
  key         String
  order       Int

  category   StatusCategory

  isStart     Boolean @default(false)
  isTerminal  Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id])
  orders   Order[]

  @@unique([workflowId, key])

  transitionsFrom WorkflowTransition[] @relation("TransitionFromStatus")
  transitionsTo   WorkflowTransition[] @relation("TransitionToStatus")
}

model WorkflowTransition {
  id             String   @id @default(cuid())
  workflowId     String
  fromStatusId   String
  toStatusId     String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workflow       Workflow       @relation(fields: [workflowId], references: [id])
  fromStatus     WorkflowStatus @relation("TransitionFromStatus", fields: [fromStatusId], references: [id])
  toStatus       WorkflowStatus @relation("TransitionToStatus", fields: [toStatusId], references: [id])

  @@unique([workflowId, fromStatusId, toStatusId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  orders    Order[]
  workflows Workflow[]
}

enum StatusCategory {
  TODO
  ACTIVE
  REVIEW
  QA
  DONE
  CANCELED
}
