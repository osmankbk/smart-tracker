generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  MEMBER
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum OrderPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedOrders Order[]       @relation("AssignedOrders")
  createdOrders  Order[]       @relation("CreatedOrders")
  activityLogs   ActivityLog[]
}

model Order {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      OrderStatus   @default(OPEN)
  priority    OrderPriority @default(MEDIUM)

  assigneeId  String?
  createdById String?

  assignee  User? @relation("AssignedOrders", fields: [assigneeId], references: [id])
  createdBy User? @relation("CreatedOrders", fields: [createdById], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]

  workflowId String?
  statusId   String?

  workflow   Workflow?       @relation(fields: [workflowId], references: [id])
  statusRef  WorkflowStatus? @relation(fields: [statusId], references: [id])
}

model ActivityLog {
  id      String  @id @default(cuid())
  orderId String
  actorId String?

  action     String
  fromStatus OrderStatus?
  toStatus   OrderStatus?

  reason String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
  actor User? @relation(fields: [actorId], references: [id])
}


model Workflow {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statuses WorkflowStatus[]
  orders   Order[]
}

model WorkflowStatus {
  id          String   @id @default(cuid())
  workflowId String

  name        String
  key         String
  order       Int

  category   StatusCategory

  isStart     Boolean @default(false)
  isTerminal  Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id])
  orders   Order[]

  @@unique([workflowId, key])
}

enum StatusCategory {
  TODO
  ACTIVE
  REVIEW
  QA
  DONE
  CANCELED
}
